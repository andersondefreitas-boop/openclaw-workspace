# Carteira Polygon (necessária para assinar ordens na Polymarket)
PRIVATE_KEY=0xSEU_PRIVATE_KEY_AQUI
WALLET_ADDRESS=0xSEU_WALLET_ADDRESS_AQUI

# API Key da Polymarket (gere em: https://polymarket.com/profile)
POLY_API_KEY=sua_api_key
POLY_API_SECRET=seu_api_secret
POLY_API_PASSPHRASE=seu_passphrase

# Telegram (opcional — para receber alertas)
TELEGRAM_TOKEN=seu_token_telegram
TELEGRAM_CHAT_ID=seu_chat_id

# Configurações de risco
BANKROLL=200
MAX_TRADE_PCT=0.05
DRY_RUN=true
